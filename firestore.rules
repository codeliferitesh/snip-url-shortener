rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function isValidUrl(url) {
      return url is string && url.size() > 0 && url.size() < 2048
        && (url.matches('https?://.*'));
    }
    function isValidSlug(slug) {
      return slug is string && slug.size() >= 3 && slug.size() <= 50
        && slug.matches('[a-zA-Z0-9_-]+');
    }

    // ── Users ────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Prevent accidental deletion
    }

    // ── Links ────────────────────────────────────────────
    match /links/{linkId} {
      // Anyone can read a link (needed for redirect resolution)
      allow read: if true;

      // Only authenticated users can create links
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && isValidUrl(request.resource.data.originalUrl)
        && isValidSlug(request.resource.data.slug)
        && request.resource.data.totalClicks == 0
        && request.resource.data.isActive == true;

      // Only owner can update their links
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId; // Can't change owner

      // Only owner can delete
      allow delete: if isOwner(resource.data.userId);
    }

    // ── Analytics ────────────────────────────────────────
    match /analytics/{eventId} {
      // Anyone can write analytics (clicks from unauthenticated redirects)
      allow create: if request.resource.data.linkId is string
        && request.resource.data.slug is string;

      // Only the link owner can read analytics
      // (reads are filtered by linkId in queries — trust the query)
      allow read: if isAuth();

      // No updates or deletes on analytics events
      allow update: if false;
      allow delete: if false;
    }
  }
}
